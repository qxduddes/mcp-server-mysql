# ── Single-connection mode (stdio-friendly fallback, used when db_id is empty) ──
# There is deliberately NO default user: leaving MYSQL_USER unset disables the
# fallback and tools return ERROR: MISSING_CREDENTIALS (audit: no root default).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
# Optional default database for the connection
MYSQL_DATABASE=

# ── Multi-profile mode (shared HTTP server) ──
# JSON map of named connection profiles; tools select one via db_id.
# Credentials never leave the server and are never accepted as tool parameters.
# DB_PROFILES={"staging":{"host":"db.internal","port":3306,"user":"mcp_ro","password":"...","database":"app_db"}}
DB_PROFILES={}

# ── TLS (audit P2-6) ──
# When true, the connection uses TLS with certificate verification REQUIRED.
# There is no option to disable verification.
MYSQL_SSL=false
# Optional CA bundle path for private CAs
MYSQL_SSL_CA=

# ── Safety limits (audit P3-10) ──
# Post-fetch row cap applied by the query tool
MYSQL_MAX_ROWS=1000
# SET SESSION MAX_EXECUTION_TIME for SELECTs, in ms (0 disables)
MYSQL_QUERY_TIMEOUT_MS=10000
# TCP connect timeout, in seconds
MYSQL_CONNECT_TIMEOUT_S=10

# ── MCP transport ──
# stdio (default) | http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8004
# Required for http transport (fail-closed). Escape hatch: MCP_ALLOW_ANON=1
MCP_AUTH_TOKEN=
